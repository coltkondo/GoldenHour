# backend/.env.example
# Copy this file to backend/.env and fill in real values.
# The backend reads this file automatically via python-dotenv.
# Never commit backend/.env to git.

# -----------------------------------------------------------------------
# REQUIRED
# -----------------------------------------------------------------------

# PostgreSQL connection string.
# For Docker Compose: use 'db' as the host → docker-compose overrides this automatically.
# For local non-Docker dev: use 'localhost' and make sure PostgreSQL is running.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/goldenhour

# JWT signing secret. Change to a long random string before deploying.
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# -----------------------------------------------------------------------
# OPTIONAL (defaults shown)
# -----------------------------------------------------------------------

# Redis connection string (required if you enable caching).
REDIS_URL=redis://localhost:6379

# Algorithm used for JWT encoding. Do not change.
ALGORITHM=HS256

# JWT token expiry in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Comma-separated list of allowed CORS origins (no spaces).
# The mobile app uses native HTTP (not a browser), so CORS only affects the admin dashboard.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# 'development' or 'production'. Controls debug logging.
ENVIRONMENT=development
DEBUG=true

# Logging Configuration
# Set LOG_LEVEL to DEBUG, INFO, WARNING, ERROR, or CRITICAL
LOG_LEVEL=INFO

# Set LOG_FORMAT to "console" for development (colorized) or "json" for production
LOG_FORMAT=console

# Optional: Set LOG_FILE to log to file with rotation (e.g., /var/log/goldenhour/app.log)
# Leave blank or omit for console-only logging
LOG_FILE=

# Log rotation size (e.g., "500 MB", "1 GB")
LOG_ROTATION=500 MB

# Log retention period (e.g., "10 days", "1 month")
LOG_RETENTION=10 days
