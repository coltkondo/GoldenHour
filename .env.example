# Root-level .env.example
# This file documents environment variables used across the project.
# Copy to .env and fill in real values. Never commit .env to git.

# -----------------------------------------------------------------------
# BACKEND (also see backend/.env.example for the backend-only version)
# -----------------------------------------------------------------------

# PostgreSQL connection string.
# When running via Docker Compose, use 'db' as the host (the container name).
# For local non-Docker dev, use 'localhost'.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/goldenhour

# Redis connection string.
REDIS_URL=redis://localhost:6379

# JWT signing secret. Change this to a long random string in production.
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# 'development' or 'production'
ENVIRONMENT=development

# -----------------------------------------------------------------------
# OPTIONAL — EXTERNAL APIs (not required for local dev)
# -----------------------------------------------------------------------

# Google Maps API key (required for Android map tiles in the mobile app).
# iOS uses Apple Maps and does not need this key.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Mapbox token (not currently used in code — reserved for future use).
MAPBOX_TOKEN=your-mapbox-token-here
